  "panels": [
    {
      "title": "Slowest Stages",
      "type": "table",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
      "datasource": {"type": "mysql", "uid": "DS_MYSQL"},
      "targets": [
        {
          "rawSql": "SELECT app_name, stage_id, duration_ms, executor_run_time_ms, gc_time_ms, shuffle_fetch_wait_time_ms, ROUND(gc_time_ms/NULLIF(duration_ms,0)*100,1) AS gc_pct, ROUND(shuffle_fetch_wait_time_ms/NULLIF(duration_ms,0)*100,1) AS shuffle_wait_pct, num_tasks FROM metric_events WHERE event_type='STAGE' AND duration_ms IS NOT NULL AND timestamp_ms>=($__unixEpochFrom()*1000) AND timestamp_ms<=($__unixEpochTo()*1000) ORDER BY duration_ms DESC LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"mappings": []},
        "overrides": [
          {"matcher": {"id": "byName", "options": "duration_ms"}, "properties": [{"id": "unit", "value": "ms"}]},
          {"matcher": {"id": "byName", "options": "executor_run_time_ms"}, "properties": [{"id": "unit", "value": "ms"}]},
          {"matcher": {"id": "byName", "options": "gc_time_ms"}, "properties": [{"id": "unit", "value": "ms"}]},
          {"matcher": {"id": "byName", "options": "shuffle_fetch_wait_time_ms"}, "properties": [{"id": "unit", "value": "ms"}]}
        ]
      },
      "options": {"showHeader": true, "footer": {"show": false}},
      "id": 1
    },
    {
      "title": "GC Overhead Trend",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "datasource": {"type": "mysql", "uid": "DS_MYSQL"},
      "targets": [
        {
          "rawSql": "SELECT (FLOOR(timestamp_ms/$__interval_ms)*$__interval_ms/1000) AS time, engine, ROUND(AVG(gc_time_ms/NULLIF(duration_ms,0))*100,1) AS avg_gc_pct FROM metric_events WHERE event_type IN ('TASK','MR_TASK') AND gc_time_ms IS NOT NULL AND duration_ms>0 AND timestamp_ms>=($__unixEpochFrom()*1000) AND timestamp_ms<=($__unixEpochTo()*1000) GROUP BY 1,engine ORDER BY 1,2",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {"mode": "palette-classic"},
          "custom": {"fillOpacity": 10, "lineWidth": 1},
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "calcs": []}
      },
      "id": 2
    },
    {
      "title": "Data Skew Detection",
      "type": "table",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "datasource": {"type": "mysql", "uid": "DS_MYSQL"},
      "targets": [
        {
          "rawSql": "SELECT app_id, stage_id, task_count, duration_skew_ratio, io_read_skew_ratio, shuffle_read_skew_ratio, gc_overhead_ratio, shuffle_wait_ratio FROM stage_governance WHERE (duration_skew_ratio>2 OR io_read_skew_ratio>2 OR shuffle_read_skew_ratio>2) AND timestamp_ms>=($__unixEpochFrom()*1000) AND timestamp_ms<=($__unixEpochTo()*1000) ORDER BY duration_skew_ratio DESC LIMIT 20",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"mappings": []},
        "overrides": [
          {"matcher": {"id": "byName", "options": "duration_skew_ratio"}, "properties": [{"id": "decimals", "value": 2}]},
          {"matcher": {"id": "byName", "options": "io_read_skew_ratio"}, "properties": [{"id": "decimals", "value": 2}]},
          {"matcher": {"id": "byName", "options": "shuffle_read_skew_ratio"}, "properties": [{"id": "decimals", "value": 2}]},
          {"matcher": {"id": "byName", "options": "gc_overhead_ratio"}, "properties": [{"id": "decimals", "value": 2}]},
          {"matcher": {"id": "byName", "options": "shuffle_wait_ratio"}, "properties": [{"id": "decimals", "value": 2}]}
        ]
      },
      "options": {"showHeader": true, "footer": {"show": false}},
      "id": 3

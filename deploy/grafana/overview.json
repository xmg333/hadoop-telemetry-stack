    {
      "title": "MR Job Success Rate",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "mysql",
        "uid": "DS_MYSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT ROUND(SUM(CASE WHEN state='SUCCEEDED' THEN 1 ELSE 0 END) * 100.0 / NULLIF(COUNT(DISTINCT job_id), 0), 1) AS value FROM mr_job_metrics WHERE timestamp_ms >= ($__unixEpochFrom() * 1000) AND timestamp_ms <= ($__unixEpochTo() * 1000)",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 80
              },
              {
                "color": "green",
                "value": 95
              }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "id": 4
    },
    {
      "title": "Success Rates by Engine",
      "type": "piechart",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "mysql",
        "uid": "DS_MYSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT SUM(CASE WHEN job_success='true' THEN 1 ELSE 0 END) AS 'Spark OK', SUM(CASE WHEN job_success='false' AND duration_ms IS NULL AND NOT EXISTS (SELECT 1 FROM job_metrics j2 WHERE j2.app_id = job_metrics.app_id AND j2.job_success='true') THEN 1 ELSE 0 END) AS 'Spark Fail', (SELECT COUNT(DISTINCT job_id) FROM mr_job_metrics WHERE state='SUCCEEDED' AND timestamp_ms >= ($__unixEpochFrom() * 1000) AND timestamp_ms <= ($__unixEpochTo() * 1000)) AS 'MR OK', (SELECT COUNT(DISTINCT job_id) FROM mr_job_metrics WHERE state!='SUCCEEDED' AND timestamp_ms >= ($__unixEpochFrom() * 1000) AND timestamp_ms <= ($__unixEpochTo() * 1000)) AS 'MR Fail', (SELECT COUNT(*) FROM hive_query_metrics WHERE success='true' AND timestamp_ms >= ($__unixEpochFrom() * 1000) AND timestamp_ms <= ($__unixEpochTo() * 1000)) AS 'Hive OK', (SELECT COUNT(*) FROM hive_query_metrics WHERE success='false' AND timestamp_ms >= ($__unixEpochFrom() * 1000) AND timestamp_ms <= ($__unixEpochTo() * 1000)) AS 'Hive Fail' FROM job_metrics WHERE timestamp_ms >= ($__unixEpochFrom() * 1000) AND timestamp_ms <= ($__unixEpochTo() * 1000)",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "pieType": "donut",
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        }
      },
      "id": 5
    },
    {
      "title": "IO Throughput by Engine",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "mysql",
        "uid": "DS_MYSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT (FLOOR(timestamp_ms / $__interval_ms) * $__interval_ms / 1000) AS time, SUM(io_bytes_read + io_bytes_written) AS 'Spark' FROM task_metrics WHERE timestamp_ms >= ($__unixEpochFrom() * 1000) AND timestamp_ms <= ($__unixEpochTo() * 1000) AND duration_ms IS NOT NULL GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        },
        {
          "rawSql": "SELECT (FLOOR(timestamp_ms / $__interval_ms) * $__interval_ms / 1000) AS time, SUM(hdfs_bytes_read + hdfs_bytes_written) AS 'MapReduce' FROM mr_job_metrics WHERE timestamp_ms >= ($__unixEpochFrom() * 1000) AND timestamp_ms <= ($__unixEpochTo() * 1000) GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "B"
        },
        {
          "rawSql": "SELECT (FLOOR(timestamp_ms / $__interval_ms) * $__interval_ms / 1000) AS time, SUM(input_bytes + output_bytes) AS 'Hive (est.)' FROM hive_query_metrics WHERE input_bytes IS NOT NULL AND output_bytes IS NOT NULL AND timestamp_ms >= ($__unixEpochFrom() * 1000) AND timestamp_ms <= ($__unixEpochTo() * 1000) GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineStyle": {
              "fill": "smooth"
            },
            "fillOpacity": 10,
            "lineWidth": 1
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        }
      },
      "id": 6,
      "description": "Spark and MR IO are measured; Hive IO values are table statistics estimates from metastore"
    },
    {
      "title": "Job Duration Trends",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "mysql",
        "uid": "DS_MYSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT (FLOOR(timestamp_ms / $__interval_ms) * $__interval_ms / 1000) AS time, AVG(duration_ms) AS 'Spark Jobs' FROM job_metrics WHERE timestamp_ms >= ($__unixEpochFrom() * 1000) AND timestamp_ms <= ($__unixEpochTo() * 1000) AND duration_ms IS NOT NULL GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        },
        {
          "rawSql": "SELECT (FLOOR(timestamp_ms / $__interval_ms) * $__interval_ms / 1000) AS time, AVG(elapsed_time_ms) AS 'MR Jobs' FROM mr_job_metrics WHERE timestamp_ms >= ($__unixEpochFrom() * 1000) AND timestamp_ms <= ($__unixEpochTo() * 1000) AND elapsed_time_ms IS NOT NULL GROUP BY 1 ORDER BY 1",
          "format": "time_series",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineStyle": {
              "fill": "smooth"
            },
            "lineWidth": 1
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": []
        }
      },
      "id": 7
    },
    {
      "title": "Recent Failed Tasks",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "datasource": {
        "type": "mysql",
        "uid": "DS_MYSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT 'Spark' AS engine, app_id AS id, stage_id, task_id, duration_ms, FROM_UNIXTIME(timestamp_ms/1000) AS time FROM task_metrics WHERE task_success='false' AND timestamp_ms >= ($__unixEpochFrom() * 1000) AND timestamp_ms <= ($__unixEpochTo() * 1000) UNION ALL SELECT 'MR' AS engine, job_id AS id, NULL AS stage_id, task_id, cpu_time_ms AS duration_ms, FROM_UNIXTIME(timestamp_ms/1000) AS time FROM mr_task_metrics WHERE state != 'SUCCEEDED' AND timestamp_ms >= ($__unixEpochFrom() * 1000) AND timestamp_ms <= ($__unixEpochTo() * 1000) ORDER BY time DESC LIMIT 50",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": []
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "duration_ms"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ms"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        }
      },
      "id": 8
    }
  ]
}

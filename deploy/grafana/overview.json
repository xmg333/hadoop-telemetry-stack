      "targets": [
        {
          "rawSql": "SELECT COUNT(DISTINCT app_id) AS value FROM task_metrics WHERE timestamp_ms >= ($__unixEpochFrom() * 1000) AND timestamp_ms <= ($__unixEpochTo() * 1000)",

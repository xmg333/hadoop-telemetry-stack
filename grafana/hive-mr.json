  "refresh": "30s",
  "schemaVersion": 39,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timezone": "utc",
  "uid": "hive-mr-telemetry",
  "title": "Hive on MR Telemetry",
  "tags": [
    "hive",
    "mr",
    "telemetry"
  ],
  "templating": {
    "list": [
      {
        "name": "hive_operation",
        "type": "query",
        "label": "Hive Operation",
        "datasource": {
          "type": "mysql",
          "uid": "DS_MYSQL"
        },
        "definition": "SELECT DISTINCT operation FROM hive_query_metrics WHERE execution_engine='mr' AND operation IS NOT NULL ORDER BY operation",
        "query": "SELECT DISTINCT operation FROM hive_query_metrics WHERE execution_engine='mr' AND operation IS NOT NULL ORDER BY operation",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "sort": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Hive-MR Queries",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "mysql",
        "uid": "DS_MYSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS value FROM hive_query_metrics WHERE timestamp_ms >= ($__unixEpochFrom() * 1000) AND timestamp_ms <= ($__unixEpochTo() * 1000) AND execution_engine='mr'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Avg Hive-MR Duration",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "mysql",
        "uid": "DS_MYSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT AVG(duration_ms) AS value FROM hive_query_metrics WHERE timestamp_ms >= ($__unixEpochFrom() * 1000) AND timestamp_ms <= ($__unixEpochTo() * 1000) AND execution_engine='mr' AND duration_ms IS NOT NULL",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5000
              },
              {
                "color": "red",
                "value": 30000
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Hive-MR IO Bytes",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "mysql",
        "uid": "DS_MYSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT SUM(input_bytes) AS value FROM hive_query_metrics WHERE timestamp_ms >= ($__unixEpochFrom() * 1000) AND timestamp_ms <= ($__unixEpochTo() * 1000) AND execution_engine='mr' AND input_bytes IS NOT NULL",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Hive-MR Table Events",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "mysql",
        "uid": "DS_MYSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS value FROM hive_table_io_metrics WHERE timestamp_ms >= ($__unixEpochFrom() * 1000) AND timestamp_ms <= ($__unixEpochTo() * 1000) AND execution_engine='mr'",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "light-purple"
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Operation Distribution",
      "type": "piechart",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "mysql",
        "uid": "DS_MYSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT operation AS metric, COUNT(*) AS value FROM hive_query_metrics WHERE timestamp_ms >= ($__unixEpochFrom() * 1000) AND timestamp_ms <= ($__unixEpochTo() * 1000) AND execution_engine='mr' AND operation IS NOT NULL GROUP BY operation ORDER BY value DESC",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        },
        "pieType": "donut",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 6,
      "title": "Duration by Operation",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "mysql",
        "uid": "DS_MYSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT (FLOOR(timestamp_ms / $__interval_ms) * $__interval_ms / 1000) AS time, operation AS metric, AVG(duration_ms) AS value FROM hive_query_metrics WHERE timestamp_ms >= ($__unixEpochFrom() * 1000) AND timestamp_ms <= ($__unixEpochTo() * 1000) AND execution_engine='mr' AND duration_ms IS NOT NULL AND operation IN ($hive_operation) GROUP BY 1, 2 ORDER BY 1, 2",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "Query Detail",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "mysql",
        "uid": "DS_MYSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT FROM_UNIXTIME(timestamp_ms/1000) AS time, query_id, operation, user_name, success, duration_ms, input_bytes, output_bytes, input_rows, output_rows FROM hive_query_metrics WHERE timestamp_ms >= ($__unixEpochFrom() * 1000) AND timestamp_ms <= ($__unixEpochTo() * 1000) AND execution_engine='mr' AND operation IN ($hive_operation) ORDER BY timestamp_ms DESC LIMIT 200",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "duration_ms"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ms"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "input_bytes"
            },
            "properties": [
              {
                "id": "unit",
                "value": "bytes"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "output_bytes"
            },
            "properties": [
              {
                "id": "unit",
                "value": "bytes"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "success"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "true": {
                        "text": "OK",
                        "color": "green",
                        "index": 0
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "false": {
                        "text": "FAIL",
                        "color": "red",
                        "index": 1
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "id": 8,
      "title": "Table IO Detail",
      "type": "table",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "datasource": {
        "type": "mysql",
        "uid": "DS_MYSQL"
      },
      "targets": [
        {
          "rawSql": "SELECT FROM_UNIXTIME(timestamp_ms/1000) AS time, query_id, table_name, table_type, operation, user_name FROM hive_table_io_metrics WHERE timestamp_ms >= ($__unixEpochFrom() * 1000) AND timestamp_ms <= ($__unixEpochTo() * 1000) AND execution_engine='mr' AND operation IN ($hive_operation) ORDER BY timestamp_ms DESC LIMIT 200",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "table_type"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "input": {
                        "text": "INPUT",
                        "color": "blue",
                        "index": 0
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "output": {
                        "text": "OUTPUT",
                        "color": "green",
                        "index": 1
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  ]
}